# =============================================================================
#  ODM Sourcing Intelligence Agent — environment configuration
#  Copy to `.env` (or `.env.local` for Next.js) and fill in your values.
# =============================================================================

# --- LLM Provider (choose one) ----------------------------------------------
# LLM_PROVIDER is inferred from whichever key is present, or set it explicitly.
LLM_PROVIDER=anthropic              # anthropic | openai
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL=claude-opus-4-6           # or e.g. gpt-5.4
LLM_TIMEOUT_MS=30000
LLM_MAX_TOKENS=4096

# --- Datastores -------------------------------------------------------------
DATABASE_URL=postgresql://user:pass@localhost:5432/odm
REDIS_URL=redis://localhost:6379    # optional; falls back to in-memory if empty

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string

# --- External tool APIs (optional; tools degrade gracefully if absent) ------
SERPAPI_KEY=                        # Google Trends via SerpApi
ALIBABA_APP_KEY=                    # Alibaba Open Platform
ALIBABA_API_ENDPOINT=               # Your Alibaba search proxy/endpoint URL
RAINFOREST_API_KEY=                 # Amazon reviews via Rainforest API
META_AD_LIBRARY_TOKEN=              # Meta (Facebook) Ad Library — competitor_ad_spy
TIKTOK_ADS_TOKEN=                   # TikTok Creative Center (reserved)

# --- Agent behavior ---------------------------------------------------------
MAX_PRODUCTS_PER_REQUEST=5
CACHE_TTL_HOURS=24
RATE_LIMIT_PER_HOUR=10
MIN_SCORE_FOR_SOURCING=7

# --- Integrations / automation ----------------------------------------------
WEBHOOK_URL=                        # Outbound alerts (trend monitor winners)
CRON_SECRET=                        # Shared secret for scheduled /api/monitor
API_KEYS=                           # Server-to-server keys "key1:userId1,key2:userId2"

# --- App --------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://tudominio.com
PORT=3001                           # used only by the Express variant
